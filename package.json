{
  "name": "frienddrop",
  "private": true,
  "version": "0.1.0",
  "description": "LAN-first P2P file sharing — AirDrop alternative",
  "scripts": {
    "dev": "turbo run dev",
    "dev:client": "turbo run dev --filter=client",
    "dev:host": "turbo run dev --filter=host-agent",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "prettier": "^3.8.3",
    "turbo": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "packageManager": "pnpm@10.0.0"
}